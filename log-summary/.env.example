# Directory mounted read-only into the container.
# Recommended: mount full /var/log and point SUMMARY_LOG_PATH to the exact file.
SUMMARY_LOG_MOUNT_DIR=/var/log

# Firewall log file path (host + container path because same mount point is used).
SUMMARY_LOG_PATH=/var/log/firewall-suite.log

# Output directory inside container (mapped to ./output in this folder).
SUMMARY_OUTPUT_DIR=/output

# Top-N items for rankings in JSON/TXT outputs.
SUMMARY_TOP_N=20

# Time window in minutes.
# 0 = analyze full file, >0 = sliding window.
SUMMARY_WINDOW_MINUTES=60

# Loop interval in seconds (ignored when SUMMARY_RUN_MODE=once).
SUMMARY_POLL_SECONDS=60

# loop = continuous generation, once = single snapshot.
SUMMARY_RUN_MODE=loop

# Status file used by healthcheck.
SUMMARY_STATUS_PATH=/output/summary.status.json

# Mark container unhealthy when consecutive empty cycles exceed this value.
SUMMARY_HEALTHCHECK_MAX_EMPTY_CYCLES=10
