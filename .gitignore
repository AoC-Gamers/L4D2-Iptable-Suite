/.vscode
/.env
/venv

# Python cache / bytecode
__pycache__/
*.py[cod]

# Docker log-summary local env and generated outputs
/log-summary/.env
/log-summary/output/*.json
/log-summary/output/*.txt
/log-summary/output/**/*.json
/log-summary/output/**/*.txt

# Temporary local analysis outputs
/tmp/*
!/tmp/.gitkeep

# GeoIP generated country prefix files
/geoip/generated/countries/*.txt
!/geoip/generated/countries/.gitkeep

# GeoIP updater local env
/geoip-updater/.env
/geoip-updater/geoip-updater.log
