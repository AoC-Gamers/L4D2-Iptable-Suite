# Equivalent to `AccountID` in GeoIP.conf. Optional for this downloader,
# but kept for operator familiarity with geoipupdate-style settings.
GEOIPUPDATE_ACCOUNT_ID=

# Equivalent to `LicenseKey` in GeoIP.conf.
GEOIPUPDATE_LICENSE_KEY=

# Equivalent to `EditionIDs` in GeoIP.conf. Space-separated is accepted.
# At least one CSV country edition must be present. Default keeps only the
# dataset needed by this firewall workflow.
GEOIPUPDATE_EDITION_IDS="GeoLite2-Country-CSV"

# Optional custom URL override. Leave empty to use the default MaxMind endpoint.
MAXMIND_DOWNLOAD_URL=

# Workspace repo mounted inside the container.
WORKSPACE_ROOT=/workspace

# Path to the firewall env file inside the mounted workspace.
ENV_FILE=/workspace/.env

# Temporary directory inside the container for downloaded archives.
DOWNLOAD_DIR=/tmp/maxmind

# Keep the downloaded zip after generation for debugging.
KEEP_ARCHIVE=false