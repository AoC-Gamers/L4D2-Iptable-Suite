# Firewall Rules (IPTables + NFTables)

# Backend execution:
# - Legacy backend: ./iptables.rules.sh
# - Modern backend: ./nftables.rules.sh
# Both entrypoints use this same .env file and modular loader.

# Optional module allowlist (comma-separated module IDs)
# Works for both backends and is merged with CLI --only.
# If set, only listed modules are executed.
# Examples:
# MODULES_ONLY="ip_chain_setup,ip_l4d2_udp_base,ip_finalize"
# MODULES_ONLY="nf_chain_setup,nf_l4d2_udp_base,nf_finalize"
MODULES_ONLY=""

# Type of iptables chain to protect
# 0: INPUT only (native servers), 1: DOCKER-USER only (containers), 2: BOTH
TYPECHAIN=0

# Docker compatibility when running TYPECHAIN=0
# true: preserves Docker forwarding/chains while still applying INPUT protection
# false: keeps full cleanup behavior (can break Docker network chains)
DOCKER_INPUT_COMPAT=false

# Auto-recover Docker chains when using TYPECHAIN=0 + DOCKER_INPUT_COMPAT=true
# true: restart Docker automatically if DOCKER-USER / DOCKER-FORWARD are missing
# false: only warns
DOCKER_CHAIN_AUTORECOVER=true

# HTTP/HTTPS ports to protect on host INPUT chain
# Format: "80,443" or ranges "8080:8090"
HTTP_HTTPS_PORTS="80,443"

# Rate and burst for NEW TCP connections to HTTP/HTTPS
# iptables format: "240/min", "60/sec", "1000/hour"
# nftables backend expects second/minute/hour/day.
HTTP_HTTPS_RATE="240/min"
HTTP_HTTPS_BURST=480

# Log prefix for blocked/abusive HTTP/HTTPS bursts
LOG_PREFIX_HTTP_HTTPS_ABUSE="HTTP_HTTPS_ABUSE: "

# Specific TCP ports to protect (optional)
# Format: "27001:27016" (range) or "27001,27002,27003" (specific)
# Empty: applies TCP protection to all L4D2_GAMESERVER_PORTS
# With value: applies protection only to these specific ports
L4D2_TCP_PROTECTION=""

# Additional TCP ports for Docker containers (rate-limiting via DOCKER-USER)
# Examples: "80,443" (HTTP/HTTPS), "8080" (HTTP-ALT), "3000:3100" (range)
# Empty: disabled. Only applies when TYPECHAIN includes container path (1 or 2)
TCP_DOCKER=""

# Custom SSH ports for the system
# Format: "22" (standard), "22022,22023,22024" (multiple), "22020:22029" (range)
# These ports are always allowed for remote administration
SSH_PORT="22022,22023"

# SSH ports for Docker containers (optional)
# Allows SSH access to specific containers. Same format as SSH_PORT
# Empty: disabled. Only applies when TYPECHAIN includes container path (1 or 2)
SSH_DOCKER=""

# SSH anti-abuse rate limiting (NEW connections)
# Format examples: "60/min", "10/sec", "600/hour"
SSH_RATE="60/min"
SSH_BURST=20

# Log prefix for blocked SSH abuse bursts
LOG_PREFIX_SSH_ABUSE="SSH_ABUSE: "

# OpenVPN support (host or Docker)
# OpenVPN rules are applied when ip_openvpn/nf_openvpn module is included

# OpenVPN protocol and port
VPN_PROTO="udp"
VPN_PORT=1194

# VPN subnet (OpenVPN server subnet)
VPN_SUBNET="10.8.0.0/24"

# VPN interface name or pattern (tun0 or tun+)
VPN_INTERFACE="tun0"

# Optional Docker bridge interface for OpenVPN-in-Docker (docker0 or br+)
VPN_DOCKER_INTERFACE=""

# LAN subnet and interface for forwarding/NAT
VPN_LAN_SUBNET="192.168.1.0/24"
VPN_LAN_INTERFACE=""

# Optional NAT for VPN clients (MASQUERADE)
VPN_ENABLE_NAT=false

# (Optional) Router/LAN alias via VPN (DNAT) to avoid client-side subnet conflicts
# Useful when the VPN client is on a network that also uses 192.0.2.0/24 and cannot reach 192.0.2.1.
# Example access: http://10.99.1.1  ->  Real router: 192.0.2.1
# If either variable is empty, no alias/DNAT rule is created.
VPN_ROUTER_REAL_IP=""
VPN_ROUTER_ALIAS_IP=""

# Optional VPN logging (limited to avoid log spam)
VPN_LOG_ENABLED=false
VPN_LOG_PREFIX="VPN_TRAFFIC: "

# Extra allowed ports (servicios adicionales)
# Formato: "puerto,puerto" o rangos "inicio:fin" (multiport)
# Vacío = no agrega excepciones extras.
UDP_ALLOW_PORTS=""
TCP_ALLOW_PORTS=""

# Source Engine game server ports (GameServer)
# These ports handle: player connections, A2S queries, Steam communication
# Standard format: "27001:27016" (16 servers), "27015" (single server)
L4D2_GAMESERVER_PORTS="27015"

# SourceTV ports (spectators and streaming)
# Separated from GameServer for better control. Only handle spectator traffic
# Standard format: "27101:27116" (matches GameServer count)
L4D2_TV_PORTS="27020"

# Server tickrate (determines cmdrate limits)
# Typical tickrates: 60 (casual), 100 - 128 (competitive)
# Used to calculate UDP limits: L4D2_CMD_LIMIT+10 (burst), L4D2_CMD_LIMIT+30 (maximum)
L4D2_CMD_LIMIT=100

# Trusted IPs (complete whitelist)
# These IPs bypass ALL rate-limits and TCP blocks
# Format: "1.2.3.4" (single IP), "1.2.3.4 5.6.7.8" (multiple space-separated)
# Use for: administrators, monitoring servers, absolutely trusted IPs
WHITELISTED_IPS=""

# Trusted domains resolved to IPv4 at apply time (merged with WHITELISTED_IPS)
# Format: "host1.example.com host2.example.com" (space-separated)
# Note: if DNS changes, re-run rules to refresh resolved IPs.
WHITELISTED_DOMAINS=""

# Detailed log prefixes for specific attack types
# These allow for more granular analysis of different attack patterns
LOG_PREFIX_INVALID_SIZE="INVALID_SIZE: "
LOG_PREFIX_MALFORMED="MALFORMED: "
LOG_PREFIX_A2S_INFO="A2S_INFO_FLOOD: "
LOG_PREFIX_A2S_PLAYERS="A2S_PLAYERS_FLOOD: "
LOG_PREFIX_A2S_RULES="A2S_RULES_FLOOD: "
LOG_PREFIX_STEAM_GROUP="STEAM_GROUP_FLOOD: "
LOG_PREFIX_L4D2_CONNECT="L4D2_CONNECT_FLOOD: "
LOG_PREFIX_L4D2_RESERVE="L4D2_RESERVE_FLOOD: "
LOG_PREFIX_UDP_NEW_LIMIT="UDP_NEW_LIMIT: "
LOG_PREFIX_UDP_EST_LIMIT="UDP_EST_LIMIT: "
LOG_PREFIX_TCP_RCON_BLOCK="TCP_RCON_BLOCK: "
LOG_PREFIX_ICMP_FLOOD="ICMP_FLOOD: "

# ============================================================================

# Persistence Notes
# - ipp.sh manages persistence for iptables backend.
# - nftables backend persistence should be managed with native nft/system methods.
#
# If you operate only one backend, keep the same variables and execute only one entrypoint.

# Log Analysis Configuration

# Path to the iptables log file
# This file contains iptables logs generated by the iptables rules
# Default location where iptables writes blocked packet information
# LOGFILE=/var/log/firewall-suite.log
LOGFILE=/var/log/firewall-suite.log

# Path to rsyslog configuration file for firewall logs
# This file configures rsyslog to capture iptables logs
# RSYSLOG_CONF=/etc/rsyslog.d/firewall-suite.conf
RSYSLOG_CONF=/etc/rsyslog.d/firewall-suite.conf

